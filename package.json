{
  "name": "live-wallpaper",
  "displayName": "Live Wallpaper",
  "description": "Set a live MP4 video as your VSCode background wallpaper",
  "version": "1.0.9",
  "publisher": "budicuy",
  "author": "budicuy",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/budicuy/live-wallpaper.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Themes"
  ],
  "keywords": [
    "background",
    "wallpaper",
    "video",
    "live wallpaper",
    "mp4"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "ui"
  ],
  "main": "./out/extension",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "vscode:uninstall": "node ./out/uninstall",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": " tsc --noEmit && biome lint ./src",
    "format": "tsc --noEmit &&biome format --write ./src",
    "check": "tsc --noEmit &&biome check --write ./src"
  },
  "contributes": {
    "commands": [
      {
        "command": "liveWallpaper.apply",
        "category": "Live Wallpaper",
        "title": "Apply and Reload"
      },
      {
        "command": "liveWallpaper.enable",
        "category": "Live Wallpaper",
        "title": "Enable and Reload"
      },
      {
        "command": "liveWallpaper.disable",
        "category": "Live Wallpaper",
        "title": "Disable and Reload"
      },
      {
        "command": "liveWallpaper.reset",
        "category": "Live Wallpaper",
        "title": "Reset to Defaults"
      },
      {
        "command": "liveWallpaper.uninstall",
        "category": "Live Wallpaper",
        "title": "Uninstall Extension"
      },
      {
        "command": "liveWallpaper.createTemplate",
        "category": "Live Wallpaper",
        "title": "Create Template Setup"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Live Wallpaper",
      "properties": {
        "liveWallpaper": {
          "type": "object",
          "description": "Live Wallpaper Configuration",
          "default": {
            "videoPath": "",
            "opacity": 0.1,
            "size": "cover",
            "enabled": true,
            "loop": true
          },
          "properties": {
            "videoPath": {
              "type": "string",
              "default": "",
              "markdownDescription": "Absolute path to an MP4 (H.264) video file to use as the background wallpaper.\n\nExamples:\n- **Linux/macOS**: `/home/user/videos/wallpaper.mp4`\n- **Windows**: `C:/Users/user/Videos/wallpaper.mp4`\n- **file:// URL**: `file:///home/user/videos/wallpaper.mp4`"
            },
            "opacity": {
              "type": "number",
              "default": 0.1,
              "minimum": 0.1,
              "maximum": 1,
              "markdownDescription": "Opacity of the video wallpaper (0.1 – 1.0). The value is scaled so that `1.0` renders at 80% actual CSS opacity to keep the UI always visible. Recommended: `0.1` – `0.5`."
            },
            "size": {
              "type": "string",
              "default": "cover",
              "enum": [
                "cover",
                "contain",
                "fill",
                "auto"
              ],
              "enumDescriptions": [
                "Scale video to fill the entire window (may crop edges)",
                "Scale video to fit within the window (may show letterboxing)",
                "Stretch video to fill the window (may distort aspect ratio)",
                "Use the video's natural size"
              ],
              "markdownDescription": "Controls how the video is sized relative to the VSCode window."
            },
            "enabled": {
              "type": "boolean",
              "default": true,
              "markdownDescription": "Enable or disable the live wallpaper. When disabled, the video background is removed from VSCode."
            },
            "loop": {
              "type": "boolean",
              "default": true,
              "markdownDescription": "Whether the video should loop continuously."
            }
          }
        }
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@vscode/sudo-prompt": "^9.3.2"
  },
  "trustedDependencies": [
    "@vscode/vsce-sign"
  ]
}
